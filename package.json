{
  "name": "@maddybo/tagcss",
  "version": "0.1.1",
  "description": "A classless CSS mini-framework that styles semantic HTML into clean responsive UI.",
  "license": "MIT",
  "keywords": [
    "css",
    "classless",
    "semantic-html",
    "framework",
    "design-system",
    "forms",
    "responsive"
  ],
  "homepage": "https://github.com/maddybo/tagcss#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maddybo/tagcss.git"
  },
  "bugs": {
    "url": "https://github.com/maddybo/tagcss/issues"
  },
  "main": "dist/tagcss.css",
  "style": "dist/tagcss.css",
  "exports": {
    ".": "./dist/tagcss.css",
    "./css": "./dist/tagcss.css",
    "./min": "./dist/tagcss.min.css",
    "./layered": "./dist/tagcss.layered.css",
    "./resetless": "./dist/tagcss.resetless.css",
    "./resetless-min": "./dist/tagcss.resetless.min.css",
    "./package.json": "./package.json"
  },
  "files": [
    "assets",
    "dist",
    "examples",
    "src",
    "docs",
    "scripts",
    "README.md",
    "index.html",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "minify": "node scripts/build.mjs",
    "dev": "python3 -m http.server 4173",
    "test:visual": "playwright test",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0"
  }
}
